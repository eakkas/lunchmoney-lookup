{
  "manifest_version": 3,
  "name": "LunchMoney Transaction Lookup",
  "version": "1.0.0",
  "description": "Lookup transactions from LunchMoney via Google and Gmail",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://my.lunchmoney.app/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://my.lunchmoney.app/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
